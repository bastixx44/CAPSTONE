rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Usuario/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /reserva/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /reserva/{parent}/agendar_reserva/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/agendar_reserva/{document} {
      allow read: if true;
    }


    match /equipamiento/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /disponibilidad/{document} {
      allow create: if request.auth != null;
      allow read: if resource.data.Usuario == /databases/$(database)/documents/Usuario/$(request.auth.uid);
      allow write: if false;
      allow delete: if request.auth != null;
    }

    match /Agenda/{document} {
      allow create: if request.auth != null;
      allow read: if resource.data.Agendador == /databases/$(database)/documents/Usuario/$(request.auth.uid);
      allow write: if false;
      allow delete: if request.auth != null;
    }
  }
}
